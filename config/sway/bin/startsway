#!/bin/bash -eu

# Don't start a new Sway session if one is already running.
if systemctl --user --quiet is-active sway-session.target; then
  echo "A Sway session is already active. Refusing to start another." >&2
  exit 1
fi

export XDG_CURRENT_DESKTOP=sway
export XDG_SESSION_DESKTOP="${XDG_SESSION_DESKTOP:-sway}"
export XDG_SESSION_TYPE=wayland

# Clear failed units left over from a previous session.
systemctl --user reset-failed

session_env=(
  PATH
  XDG_CURRENT_DESKTOP
  XDG_SESSION_DESKTOP
  XDG_SESSION_TYPE
  XDG_CONFIG_HOME
  XDG_DATA_HOME
  XDG_CACHE_HOME
  XDG_STATE_HOME
)
systemctl --user import-environment "${session_env[@]}"

# Set theme env vars before Sway starts so other services see them too.
"${XDG_CONFIG_HOME:-$HOME/.config}"/sway/bin/import-gsettings.sh

# Stop everything bound to the session instead of crash-looping against a dead compositor.
session_cleanup() {
  systemctl --user start --job-mode=replace-irreversibly sway-session-shutdown.target
  systemctl --user unset-environment "${session_env[@]}" GTK_THEME XCURSOR_THEME XCURSOR_SIZE
}
trap 'session_cleanup; exit' INT TERM

systemctl --wait --user start sway.service || true

session_cleanup
