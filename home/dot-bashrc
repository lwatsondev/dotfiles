#!/bin/bash

if [[ $- != *i* ]]; then
  return
fi

# PAM has no mechanism to apply environment.d to login sessions:
# https://github.com/systemd/systemd/issues/7641
if command -v systemctl &> /dev/null && systemctl --user show-environment &> /dev/null; then
  # shellcheck disable=SC1090
  source <(systemctl --user show-environment | sed 's/^/export /')
else
  # No systemd --user, e.g. Termux.
  for f in "${XDG_CONFIG_HOME:-$HOME/.config}"/environment.d/*.conf; do
    if [[ -f $f ]]; then
      set -a
      # shellcheck disable=SC1090
      source "$f" 2> /dev/null
      set +a
    fi
  done
fi

fish_path=$(command -v fish)

# Drop into fish only if the parent process is not fish. Allows dropping directly into bash from fish without having to use --norc
[[ $(ps --no-header --pid=$PPID --format=comm) != "fish" ]] && [[ -z ${BASH_EXECUTION_STRING} ]] && [[ -x $fish_path ]] && exec "$fish_path"
